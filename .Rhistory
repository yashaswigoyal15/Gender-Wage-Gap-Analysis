data<-read.csv("wage_clean.csv")
library(tidyverse)
setwd("C:/Users/hp/Downloads/Gender Project")
data<-read.csv("wage_clean.csv")
head(data)
glimpse(data)
sector_summary <- data %>%
group_by(Sector) %>%
summarise(Avg_WageGap = mean(WageGap, na.rm = TRUE)) %>%
arrange(desc(Avg_WageGap))
print(sector_summary)
arrange(desc(Avg_WageGap))
country_summary <- data %>%
group_by(Country) %>%
summarise(Avg_WageGap = mean(WageGap, na.rm = TRUE)) %>%
arrange(desc(Avg_WageGap))
print(country_summary)
year_summary <- data %>%
group_by(Year) %>%
summarise(Avg_WageGap = mean(WageGap, na.rm = TRUE))
print(year_summary)
model <- lm(WageGap ~ Sector_Education + Sector_Finance + Sector_Health + Sector_Professional + Sector_Retail + Region_Europe + Region_LatAm + Region_Asia_Dev + Region_Asia_Africa_Dev + Year, data = data)
summary(model)
library(ggplot2)
ggplot(sector_summary, aes(x = reorder(Sector, Avg_WageGap), y = Avg_WageGap)) + geom_bar(stat = "identity", fill = "steelblue") + coord_flip() + labs(title = "Average Gender Wage Gap by Sector",x = "Sector",y = "Wage Gap (%)") +  theme_minimal()
ggplot(country_summary, aes(x = reorder(Country, Avg_WageGap), y = Avg_WageGap)) +geom_bar(stat = "identity", fill = "coral") +coord_flip() +labs(title = "Average Gender Wage Gap by Country",x = "Country",y = "Wage Gap (%)") +theme_minimal()
ggplot(year_summary, aes(x = Year, y = Avg_WageGap)) +geom_line(color = "darkred", size = 1.2) +geom_point(size = 3) +labs(title = "Gender Wage Gap Trend 2018–2023",x = "Year",y = "Average Wage Gap (%)") +theme_minimal()
residual_data <- data.frame(Fitted = fitted(model),Residuals = residuals(model))
ggplot(residual_data, aes(x = Fitted, y = Residuals)) +geom_point(alpha = 0.5, color = "steelblue") +geom_hline(yintercept = 0, linetype = "dashed", color = "red") +labs(title = "Residuals vs Fitted Values", x = "Fitted Values",y = "Residuals") +theme_minimal()
load("C:/Users/hp/Downloads/Gender Project/.RData")
