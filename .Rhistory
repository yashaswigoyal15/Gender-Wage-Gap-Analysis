# ── 0. Packages ──────────────────────────────────────────────────────────────
install.packages(c("learningtower","dplyr","ggplot2","stargazer"))
library(learningtower)
library(dplyr)
library(ggplot2)
library(stargazer)
# ── 1. Load data ──────────────────────────────────────────────────────────────
student_2022 <- load_student(2022)
# ── 2. Filter to ONE country (change "GBR" to your preferred country)
# Options: "GBR" "DEU" "BRA" "AUS" "USA" "IND" (check if IND is present)
df <- student_2022 %>% filter(country == "GBR")
cat("Students in sample:", nrow(df), "\n")
cat("Countries available:", paste(unique(student_2022$country)[1:20], collapse=", "))
# ── 3. Check what countries are available
table(student_2022$country)
# ── 4. Clean: drop rows missing key variables ──────────────────────────────
df_clean <- df %>%
filter(!is.na(math), !is.na(escs), !is.na(gender), !is.na(wealth))
cat("Clean sample size:", nrow(df_clean), "\n")
# ── 5. Create a numeric gender variable (1 = female, 0 = male) ──────────────
df_clean <- df_clean %>%
mutate(female = ifelse(gender == "female", 1, 0))
# ── 6. Summary statistics ────────────────────────────────────────────────────
summary(df_clean[, c("math","read","science","escs","wealth","female")])
# ── 7. Three OLS models (add controls step by step) ─────────────────────────
m1 <- lm(math ~ escs,                          data = df_clean)
